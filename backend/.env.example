# Backend environment example
# Copy to backend/.env only if you run the backend with env-file tooling.
# The fastest local dev path is SPRING_PROFILES_ACTIVE=local, which uses H2.

# Local H2 profile
SPRING_PROFILES_ACTIVE=local
JWT_SECRET=replace_with_base64_encoded_256_bit_secret
ADMIN_BOOTSTRAP_SECRET=replace-with-your-private-admin-secret

# MySQL runtime profile
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/nexoria?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=nexoria
SPRING_DATASOURCE_PASSWORD=change_me_database_password

# Frontend origin allowed by CORS during local dev
APP_CORS_ALLOWED_ORIGIN=http://localhost:3000
