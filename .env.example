# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nexoria
DB_USERNAME=nexoria
DB_PASSWORD=change_me_database_password
DB_ROOT_PASSWORD=change_me_root_password

# JWT Configuration (MUST be changed for production)
JWT_SECRET=replace_with_base64_encoded_256_bit_secret

# API Configuration
API_BASE_URL=http://localhost:8080/api

# Application Configuration
SPRING_PROFILES_ACTIVE=dev
APP_CORS_ALLOWED_ORIGIN_1=http://localhost:3000
APP_CORS_ALLOWED_ORIGIN_2=http://localhost:8080

# Production reverse proxy configuration
APP_DOMAIN=app.nexoria.example
APP_CORS_ALLOWED_ORIGIN=https://app.nexoria.example

# Security headers
APP_SECURITY_CSP=default-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; img-src 'self' data: https:; script-src 'self'; style-src 'self' 'unsafe-inline' https:; connect-src 'self' https://app.nexoria.example;
APP_SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
APP_SECURITY_PERMISSIONS_POLICY=camera=(), geolocation=(), microphone=()
APP_SECURITY_HSTS_ENABLED=true
APP_SECURITY_HSTS_MAX_AGE_SECONDS=31536000
APP_SECURITY_HSTS_INCLUDE_SUBDOMAINS=true

# Auth endpoint protection
APP_RATE_LIMIT_AUTH_ENABLED=true
APP_RATE_LIMIT_AUTH_CAPACITY=10
APP_RATE_LIMIT_AUTH_WINDOW=PT1M
